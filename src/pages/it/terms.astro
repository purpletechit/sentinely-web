---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LegalBody from '../../components/pages/LegalBody.astro';
import { useTranslations, type Lang } from '../../i18n/utils';

const lang = (Astro.currentLocale ?? 'it') as Lang;
const t = useTranslations(lang);
---

<BaseLayout title={t('pages.terms.title')} description={t('pages.terms.description')}>
  <LegalBody doc="terms" />
</BaseLayout>
