---
interface Props {
  eyebrow?: string;
  title: string;
  sub?: string;
}
const { eyebrow, title, sub } = Astro.props;
---

<section class="page-hero">
  <div class="container">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1 class="page-title">{title}</h1>
    {sub && <p class="page-sub measure">{sub}</p>}
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    padding-top: 3.5rem;
    padding-bottom: 2.25rem;
    overflow: clip;
  }
  .page-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(55% 60% at 15% 0%, var(--accent-soft), transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  .page-hero .container {
    position: relative;
    z-index: 1;
  }
  .page-title {
    font-size: clamp(2rem, 1.4rem + 3vw, 3.1rem);
    margin-top: 0.9rem;
    max-width: 18ch;
  }
  .page-sub {
    margin-top: 1.1rem;
    font-size: 1.1rem;
    color: var(--muted);
  }
  @media (min-width: 768px) {
    .page-hero {
      padding-top: 4.5rem;
      padding-bottom: 3rem;
    }
  }
</style>
