---
import { useTranslations, type Lang } from '../i18n/utils';

const lang = (Astro.currentLocale ?? 'en') as Lang;
const t = useTranslations(lang);
---

<button
  type="button"
  class="theme-toggle"
  data-theme-toggle
  aria-label={t('common.themeToggle')}
  title={t('common.themeToggle')}
>
  <svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
    <path
      d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5Z"
      stroke="currentColor"
      stroke-width="1.7"
      stroke-linejoin="round"></path>
  </svg>
  <svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
    <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.7"></circle>
    <path
      d="M12 2.5v2M12 19.5v2M4.5 12h-2M21.5 12h-2M5.6 5.6 4.2 4.2M19.8 19.8l-1.4-1.4M18.4 5.6l1.4-1.4M4.2 19.8l1.4-1.4"
      stroke="currentColor"
      stroke-width="1.7"
      stroke-linecap="round"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
    background-color: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: color 0.14s ease, border-color 0.14s ease, background-color 0.14s ease;
  }
  .theme-toggle:hover {
    color: var(--accent);
    border-color: var(--accent-solid);
    background-color: var(--accent-soft);
  }
</style>
