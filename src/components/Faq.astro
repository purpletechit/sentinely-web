---
import SectionHeading from './SectionHeading.astro';
import { useTranslations, type Lang } from '../i18n/utils';

const lang = (Astro.currentLocale ?? 'en') as Lang;
const t = useTranslations(lang);

type Item = { q: string; a: string };
const items = t('faq.items') as Item[];
---

<section id="faq" class="section faq">
  <div class="container faq-inner">
    <SectionHeading eyebrow={t('faq.eyebrow')} title={t('faq.heading')} />
    <div class="faq-list reveal">
      {items.map((item, i) => (
        <details class="faq-item" name="faq" open={i === 0}>
          <summary class="faq-q">
            <span>{item.q}</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
              <path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </summary>
          <div class="faq-a"><p>{item.a}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-inner {
    display: grid;
    gap: 2.25rem;
    grid-template-columns: 1fr;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background-color: var(--surface);
    overflow: hidden;
  }
  .faq-item {
    border-bottom: 1px solid var(--line);
  }
  .faq-item:last-child {
    border-bottom: none;
  }
  .faq-q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.15rem 1.35rem;
    cursor: pointer;
    font-weight: 650;
    color: var(--strong);
    font-size: 1.02rem;
    list-style: none;
  }
  .faq-q::-webkit-details-marker {
    display: none;
  }
  .faq-q:hover {
    color: var(--accent);
  }
  .faq-chevron {
    flex: none;
    color: var(--muted);
    transition: transform 0.2s ease;
  }
  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
    color: var(--accent);
  }
  .faq-a {
    padding: 0 1.35rem 1.25rem;
    color: var(--muted);
    font-size: 0.97rem;
    line-height: 1.65;
    max-width: 68ch;
  }

  @media (min-width: 900px) {
    .faq-inner {
      grid-template-columns: 0.8fr 1.2fr;
      align-items: start;
      gap: 3rem;
    }
  }
</style>
