---
import Icon from './Icon.astro';
import SectionHeading from './SectionHeading.astro';
import { pricingTiers } from '../data/pricing';
import { localizePath, useTranslations, type Lang } from '../i18n/utils';

const lang = (Astro.currentLocale ?? 'en') as Lang;
const t = useTranslations(lang);

type TierCopy = {
  name: string;
  tagline: string;
  features: string[];
  cta: string;
  badge?: string;
  priceLabel?: string;
};
---

<section id="pricing" class="section pricing">
  <div class="container">
    <SectionHeading
      eyebrow={t('pricing.eyebrow')}
      title={t('pricing.heading')}
      sub={t('pricing.sub')}
      align="center"
    />

    <div class="pricing-grid">
      {pricingTiers.map((tier) => {
        const copy = t(`pricing.tiers.${tier.id}`) as TierCopy;
        const href = tier.ctaKind === 'contact' ? localizePath(tier.ctaHref, lang) : tier.ctaHref;
        return (
          <article class:list={['tier', 'reveal', { highlighted: tier.highlighted }]}>
            {tier.highlighted && <span class="tier-flag mono">{t('pricing.mostPopular')}</span>}
            <div class="tier-head">
              <h3 class="tier-name">{copy.name}</h3>
              {copy.badge && <span class="chip chip-accent tier-badge">{copy.badge}</span>}
            </div>
            <p class="tier-price">
              {tier.price !== null ? (
                <>
                  <span class="mono price-amount">{tier.currencySymbol}{tier.price}</span>
                  <span class="price-period">{t('pricing.perMonth')}</span>
                </>
              ) : (
                <span class="mono price-amount">{copy.priceLabel}</span>
              )}
            </p>
            <p class="tier-tagline">{copy.tagline}</p>
            <a href={href} class:list={['btn', 'btn-block', tier.highlighted ? 'btn-primary' : 'btn-ghost']}>
              {copy.cta}
            </a>
            <ul class="tier-features">
              {copy.features.map((feat) => (
                <li>
                  <span class="feat-check" aria-hidden="true"><Icon name="check" size={15} /></span>
                  <span>{feat}</span>
                </li>
              ))}
            </ul>
          </article>
        );
      })}
    </div>

    <p class="pricing-footnote mono">{t('pricing.footnote')}</p>
  </div>
</section>

<style>
  .pricing-grid {
    margin-top: 2.75rem;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
    align-items: start;
  }
  .tier {
    position: relative;
    padding: 1.75rem 1.5rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background-color: var(--surface);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .tier.highlighted {
    border-color: var(--accent-solid);
    box-shadow: 0 0 0 1px var(--accent-solid), var(--shadow-lg);
  }
  .tier-flag {
    position: absolute;
    top: -0.7rem;
    left: 1.5rem;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 700;
    color: var(--btn-fg);
    background-color: var(--accent-solid);
    padding: 0.28rem 0.6rem;
    border-radius: 999px;
  }
  .tier-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .tier-name {
    font-size: 1.25rem;
    font-weight: 750;
    color: var(--strong);
  }
  .tier-badge {
    font-size: 0.66rem;
  }
  .tier-price {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
  }
  .price-amount {
    font-size: 2.2rem;
    font-weight: 780;
    color: var(--strong);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .price-period {
    color: var(--muted);
    font-size: 0.95rem;
  }
  .tier-tagline {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.5;
    min-height: 2.8em;
  }
  .tier-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    margin-top: 0.35rem;
  }
  .tier-features li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.92rem;
    color: var(--ink);
  }
  .feat-check {
    display: inline-grid;
    place-items: center;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 999px;
    background-color: var(--pass-soft);
    color: var(--pass);
    flex: none;
    margin-top: 0.05rem;
  }
  .pricing-footnote {
    margin-top: 1.75rem;
    text-align: center;
    color: var(--faint);
    font-size: 0.75rem;
  }
  @media (min-width: 860px) {
    .pricing-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .tier.highlighted {
      transform: translateY(-0.5rem);
    }
  }
</style>
