---
import Icon from './Icon.astro';

interface Props {
  icon: string;
  title: string;
  body: string;
  delay?: number;
}
const { icon, title, body, delay = 0 } = Astro.props;
---

<article class="feature card reveal" style={delay ? `transition-delay:${delay}ms` : undefined}>
  <span class="feature-icon" aria-hidden="true">
    <Icon name={icon} size={22} />
  </span>
  <h3 class="feature-title">{title}</h3>
  <p class="feature-body">{body}</p>
</article>

<style>
  .feature {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    height: 100%;
    transition:
      opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }
  .feature:hover {
    border-color: var(--accent-line);
    box-shadow: var(--shadow-lg);
  }
  .feature-icon {
    display: inline-grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: var(--radius-sm);
    background-color: var(--accent-soft);
    color: var(--accent);
    border: 1px solid var(--accent-line);
    margin-bottom: 0.25rem;
  }
  .feature-title {
    font-size: 1.08rem;
    font-weight: 700;
    color: var(--strong);
    letter-spacing: -0.01em;
  }
  .feature-body {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }
</style>
