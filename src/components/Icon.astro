---
interface Props {
  name: string;
  size?: number;
  class?: string;
}
const { name, size = 22, class: className } = Astro.props;
const sw = 1.7;
---

<svg
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  aria-hidden="true"
  class={className}
  stroke-linecap="round"
  stroke-linejoin="round"
>
  {name === 'gauge' && (
    <>
      <path d="M4 16a8 8 0 0 1 16 0" stroke="currentColor" stroke-width={sw} />
      <path d="m12 16 4.2-4.6" stroke="currentColor" stroke-width={sw} />
      <circle cx="12" cy="16" r="1.15" fill="currentColor" />
    </>
  )}
  {name === 'sparkles' && (
    <>
      <path
        d="M11 3.2 12.7 8 17.4 9.7 12.7 11.4 11 16.2 9.3 11.4 4.6 9.7 9.3 8 11 3.2Z"
        stroke="currentColor"
        stroke-width={sw}
      />
      <path d="M18 14.2 18.9 16.6 21.3 17.5 18.9 18.4 18 20.8 17.1 18.4 14.7 17.5 17.1 16.6 18 14.2Z" fill="currentColor" />
    </>
  )}
  {name === 'bell' && (
    <>
      <path d="M6 9a6 6 0 0 1 12 0c0 4 1.1 5.6 1.9 6.5H4.1C4.9 14.6 6 13 6 9Z" stroke="currentColor" stroke-width={sw} />
      <path d="M10 19a2 2 0 0 0 4 0" stroke="currentColor" stroke-width={sw} />
    </>
  )}
  {name === 'shield' && (
    <>
      <path d="M12 3 5 6v5c0 4.4 3 8 7 9 4-1 7-4.6 7-9V6l-7-3Z" stroke="currentColor" stroke-width={sw} />
      <path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width={sw} />
    </>
  )}
  {name === 'radar' && (
    <>
      <path d="M20 12a8 8 0 1 1-4.6-7.2" stroke="currentColor" stroke-width={sw} />
      <path d="M12 12 20 5" stroke="currentColor" stroke-width={sw} />
      <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width={sw} />
      <circle cx="12" cy="12" r="1" fill="currentColor" />
    </>
  )}
  {name === 'layers' && (
    <>
      <path d="m12 4 8 4-8 4-8-4 8-4Z" stroke="currentColor" stroke-width={sw} />
      <path d="m4 12 8 4 8-4" stroke="currentColor" stroke-width={sw} />
      <path d="m4 16 8 4 8-4" stroke="currentColor" stroke-width={sw} />
    </>
  )}
  {name === 'eye-off' && (
    <>
      <path d="M3 3.5 20.5 21" stroke="currentColor" stroke-width={sw} />
      <path d="M10.6 6.2A9.6 9.6 0 0 1 12 6c5 0 8.6 4.5 9.5 6-.4.8-1.3 2-2.6 3.2M6.2 7.9C4.1 9.1 2.9 11 2.5 12c1 1.5 4.5 6 9.5 6 1.3 0 2.6-.3 3.7-.8" stroke="currentColor" stroke-width={sw} />
      <path d="M9.9 10.2a3 3 0 0 0 4 4" stroke="currentColor" stroke-width={sw} />
    </>
  )}
  {name === 'mail-x' && (
    <>
      <path d="M20 8.6V17a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h9.5" stroke="currentColor" stroke-width={sw} />
      <path d="m2.5 7 9 5.6L15 10.5" stroke="currentColor" stroke-width={sw} />
      <path d="m17 4.5 4 4m0-4-4 4" stroke="currentColor" stroke-width={sw} />
    </>
  )}
  {name === 'lock-open' && (
    <>
      <rect x="4.5" y="10.5" width="15" height="9.5" rx="2" stroke="currentColor" stroke-width={sw} />
      <path d="M8 10.5V8a4 4 0 0 1 7.7-1.5" stroke="currentColor" stroke-width={sw} />
      <circle cx="12" cy="15.2" r="1.3" fill="currentColor" />
    </>
  )}
  {name === 'check' && <path d="m5 12.5 4 4 10-10" stroke="currentColor" stroke-width="2" />}
  {name === 'arrow-right' && <path d="M5 12h13m-6-6 6 6-6 6" stroke="currentColor" stroke-width="1.9" />}
  {name === 'mail' && (
    <>
      <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width={sw} />
      <path d="m3.5 7 8.5 6 8.5-6" stroke="currentColor" stroke-width={sw} />
    </>
  )}
</svg>
