---
import CompanyBlock from '../CompanyBlock.astro';
import { useTranslations, type Lang } from '../../i18n/utils';

interface Props {
  doc: 'privacy' | 'terms' | 'gdpr';
}
const { doc } = Astro.props;

const lang = (Astro.currentLocale ?? 'en') as Lang;
const t = useTranslations(lang);

type Section = { heading: string; body: string };
const sections = t(`legal.${doc}.sections`) as Section[];
---

<section class="legal-hero">
  <div class="container">
    <p class="eyebrow">{t('footer.colLegal')}</p>
    <h1 class="legal-title">{t(`legal.${doc}.title`)}</h1>
    <p class="legal-updated mono">{t('legal.lastUpdated')}: {t('legal.lastUpdatedValue')}</p>
  </div>
</section>

<section class="section section-top">
  <div class="container legal-grid">
    <div class="legal-content">
      <div class="legal-notice">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"></circle>
          <path d="M12 11v5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path>
          <circle cx="12" cy="7.75" r="1.05" fill="currentColor"></circle>
        </svg>
        <p>{t('legal.placeholderNotice')}</p>
      </div>

      <p class="legal-intro">{t(`legal.${doc}.intro`)}</p>

      <div class="legal-sections">
        {sections.map((section) => (
          <section class="legal-section">
            <h2 class="legal-section-heading">{section.heading}</h2>
            <p class="legal-section-body">{section.body}</p>
          </section>
        ))}
      </div>
    </div>

    <CompanyBlock heading={t('legal.contactHeading')} />
  </div>
</section>

<style>
  .legal-hero {
    padding-top: 3.5rem;
    padding-bottom: 1rem;
  }
  .legal-title {
    font-size: clamp(1.9rem, 1.4rem + 2.6vw, 2.8rem);
    margin-top: 0.8rem;
  }
  .legal-updated {
    margin-top: 0.9rem;
    color: var(--faint);
    font-size: 0.8rem;
  }
  .section-top {
    padding-top: 1.5rem;
  }
  .legal-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  .legal-notice {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    padding: 1rem 1.1rem;
    border-radius: var(--radius);
    background-color: var(--warn-soft);
    border: 1px solid color-mix(in srgb, var(--warn) 35%, var(--line));
    color: var(--warn);
    margin-bottom: 2rem;
  }
  .legal-notice svg {
    flex: none;
    margin-top: 0.1rem;
  }
  .legal-notice p {
    font-size: 0.88rem;
    line-height: 1.55;
    font-weight: 550;
  }
  .legal-intro {
    color: var(--ink);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 65ch;
    margin-bottom: 2rem;
  }
  .legal-sections {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }
  .legal-section-heading {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--strong);
    margin-bottom: 0.55rem;
  }
  .legal-section-body {
    color: var(--muted);
    font-size: 0.98rem;
    line-height: 1.7;
    max-width: 65ch;
  }
  @media (min-width: 900px) {
    .legal-grid {
      grid-template-columns: 1.7fr 1fr;
      gap: 3.5rem;
    }
  }
</style>
