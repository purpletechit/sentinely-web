# Build-time PUBLIC variable (safe to expose in the client bundle).
# Read by `astro build` and embedded into the Turnstile form widget.
# Copy to `.env` locally, or set it in the Cloudflare Pages build settings.
# The value below is Cloudflare's "always passes" TEST site key for local dev.
PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
